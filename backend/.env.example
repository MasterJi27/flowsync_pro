# For Supabase configuration, see .env.supabase.example
NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://flowsync:flowsync@localhost:5432/flowsync_pro?schema=public
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=8h
INVITE_EXPIRES_HOURS=168
CORS_ORIGIN=http://localhost:3000,http://localhost:8080
TRUST_PROXY=false
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=120
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX_REQUESTS=25
OVERDUE_SWEEP_CRON=*/1 * * * *
ESCALATION_STEP_MINUTES=5
