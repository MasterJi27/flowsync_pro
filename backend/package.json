{
  "name": "flowsync-pro-backend",
  "version": "1.0.0",
  "private": true,
  "description": "FlowSync Pro logistics execution backend",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "check": "npm run typecheck && npm run build && npm run prisma:generate",
    "check:db": "tsx scripts/check-db.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma db push && prisma db execute --file prisma/migrations/000001_immutable_logs/migration.sql --schema prisma/schema.prisma",
    "db:setup": "prisma db push && prisma db execute --file prisma/migrations/000001_immutable_logs/migration.sql --schema prisma/schema.prisma",
    "seed": "tsx prisma/seed.ts",
    "demo:flow": "tsx scripts/demo-flow.ts",
    "typecheck": "tsc --noEmit",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dayjs": "^1.11.13",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^8.4.1",
    "firebase-admin": "^13.8.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^3.0.3",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "socket.io": "^4.8.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.5",
    "@types/node-cron": "^3.0.11",
    "pino-pretty": "^13.1.3",
    "prisma": "^6.19.3",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3"
  }
}
